rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Separate profiles per role
    match /aspirantes_demo/{uid} { 
      allow read, write: if request.auth != null && request.auth.uid == uid; 
    }
    match /judges/{uid} { 
      allow read, write: if request.auth != null && request.auth.uid == uid; 
    }
    match /medicos/{uid} { 
      allow read, write: if request.auth != null && request.auth.uid == uid; 
    }
    match /admins/{uid} { 
      allow read, write: if request.auth != null && request.auth.uid == uid; 
    }
    match /arbitros/{uid} { 
      allow read, write: if request.auth != null && request.auth.uid == uid; 
    }
    match /directores/{uid} { 
      allow read, write: if request.auth != null && request.auth.uid == uid; 
    }
    match /tribunales/{uid} { 
      allow read, write: if request.auth != null && request.auth.uid == uid; 
    }

    // Role mappings collection - only allow admin write, anyone can read to verify role
    match /user_roles/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'elvialeonsh@gmail.com';
    }
  }
}
